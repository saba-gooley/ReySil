# =========================================================================
# ReySil — Variables de entorno
# =========================================================================
# Copiar a .env.local y completar con valores reales.
# NUNCA commitear .env.local — esta en .gitignore
# =========================================================================

# ---------- Supabase ----------
# Crear proyecto en https://supabase.com/dashboard
# URL y anon key se encuentran en: Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...

# Service role key — bypassea RLS, usar SOLO server-side
# Project Settings → API → service_role secret
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# ---------- SendGrid ----------
# https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxx
SENDGRID_FROM_EMAIL=notificaciones@reysil.com
SENDGRID_FROM_NAME=Transportes ReySil

# ---------- Google Drive ----------
# Service account JSON codificado en base64
# Generar desde: https://console.cloud.google.com/iam-admin/serviceaccounts
# Base64: cat service-account.json | base64
GOOGLE_DRIVE_SERVICE_ACCOUNT_KEY=eyJ0eXBlIjoic2VydmljZV9hY2...

# IDs de carpetas en Drive donde se guardan los archivos
GOOGLE_DRIVE_FOLDER_REMITOS=1AbCdEfGhIjKlMnOpQrStUvWxYz
GOOGLE_DRIVE_FOLDER_INSPECCIONES=1AbCdEfGhIjKlMnOpQrStUvWxYz

# ---------- WhatsApp ----------
# Numero de la empresa con codigo de pais, sin + ni espacios
NEXT_PUBLIC_WHATSAPP_PHONE_NUMBER=5491100000000

# ---------- App ----------
NEXT_PUBLIC_APP_URL=http://localhost:3000
